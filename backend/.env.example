# Copy to `.env` locally or set these in your hosting dashboard.
# Never commit real secrets here.

NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-frontend-domain.example
BACKEND_URL=https://your-backend-domain.example

# --- Core auth / database ---
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<database>
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY=24h

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# --- Email / forgot-password / welcome mail ---
EMAIL_USER=youraddress@gmail.com
EMAIL_PASSWORD=your-16-char-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_FROM="Dwarakamai digital photo studio" <youraddress@gmail.com>

# --- WhatsApp ---
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_VERIFY_TOKEN=your-whatsapp-verify-token
WHATSAPP_NUMBER=919999999999

# --- Payments ---
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
PAYTM_MERCHANT_ID=your-paytm-merchant-id
PAYTM_MERCHANT_KEY=your-paytm-merchant-key
PAYTM_WEBSITE=WEBSTAGING
PAYTM_INDUSTRY_TYPE=Retail
PAYTM_CHANNEL_ID_WEB=WEB
PAYTM_CHANNEL_ID_APP=WAP
PAYTM_GATEWAY_URL=https://securegw-stage.paytm.in/order/initiate
PAYTM_VERIFY_URL=https://securegw-stage.paytm.in/merchant-status/?cmd=get:TransactionDetail

# --- Feature flags ---
ENABLE_TEST_PAYMENTS=false
EXPOSE_DEV_OTP_IN_RESPONSE=false
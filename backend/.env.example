# Copy to `.env` on the server. For PaaS (Render, Railway, etc.), set these in the dashboard instead.

# --- Nodemailer / forgot-password & welcome email ---
# Gmail: use a Google Account with 2-Step Verification and create an App Password
# (Google Account → Security → App passwords). Do not use your normal Gmail password.
EMAIL_USER=youraddress@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# Optional: override SMTP (defaults: Gmail smtp.gmail.com:587)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_SECURE=false
# Optional: full From header (default: "Geethika Digital World" <EMAIL_USER>)
# EMAIL_FROM="Geethika Digital World" <youraddress@gmail.com>

# If OTP still fails in production:
# - Confirm EMAIL_USER / EMAIL_PASSWORD are set on the *host* (not only local .env).
# - Many cloud hosts block outbound port 25; use 587 (STARTTLS) or 465 (SSL) with EMAIL_SECURE=true.
# - If Gmail blocks datacenter IPs, use Resend, SendGrid, Mailgun, or AWS SES and set EMAIL_HOST accordingly.

# Never set this in production. When true (local only), forgot-password API may return devOTP for UI testing.
# EXPOSE_DEV_OTP_IN_RESPONSE=true

NODE_ENV=production
